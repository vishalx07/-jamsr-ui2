{
  "extends": "@jamsrui/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./public/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts",
    "../../packages/ui/src/alert.tsx",
    "../../packages/ui/src/button.tsx",
    "../../packages/ui/src/select.tsx"
  ],
  "exclude": ["node_modules"]
}
